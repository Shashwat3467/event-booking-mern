{
  "name": "event-booking-application-mern",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "setup": "npm run install:all",
    "install:all": "npm run install-all",
    "install-all": "npm install --prefix server && npm install --prefix client/EVENTER",
    "server": "npm run dev --prefix server",
    "client": "npm run dev --prefix client/EVENTER",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "build": "npm run build --prefix client/EVENTER",
    "start": "npm run start --prefix server"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
